{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6", "dom"],
    "types": ["cypress", "node"],
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["cypress/**/*.ts"]
}